(* WitnessExtraction: Coq→OCaml extraction for PO-8 completeness
 *
 * This module extracts the varint-based witness encoding functions to OCaml,
 * producing an executable that generates golden test vectors for comparison
 * against the Rust implementation.
 *
 * Copyright (c) 2026 Mayckon Giovani. MIT License.
 *)

From Stdlib Require Import Extraction.
From Stdlib Require Import Ascii.
From Stdlib Require Import String.

(* Import existing verified modules - use BitcoinPQ namespace *)
From BitcoinPQ Require Import VarintConcrete.
From BitcoinPQ Require Import SpendPredPQ.

(* ================================================================= *)
(* Extraction configuration                                          *)
(* ================================================================= *)

(* Extract native Coq types to OCaml equivalents *)
Extract Inductive bool => "bool" [ "true" "false" ].
Extract Inductive list => "list" [ "[]" "(::)" ].
Extract Inductive option => "option" [ "None" "Some" ].
Extract Inductive prod => "( * )" [ "(,)" ].

(* Extract nat to int for efficiency (witness sizes are bounded) *)
Extract Inductive nat => int [ "0" "succ" ]
  "(fun fO fS n -> if n=0 then fO () else fS (n-1))".

(* ================================================================= *)
(* Witness encoding functions for extraction                         *)
(* ================================================================= *)

(* Encode a nat using Bitcoin compact-size varint *)
Definition encode_varint_nat (n : nat) : list nat :=
  encode_len_multi n.

(* Decode a varint from a byte list *)
Definition decode_varint_nat (data : list nat) : option (nat * nat) :=
  decode_len_multi data.

(* Serialize a witness: pk_len || pk || sig_len || sig *)
Definition serialize_witness_extract (pk : list nat) (sig : list nat) : list nat :=
  serialize_witness_concrete pk sig.

(* Parse a witness into (pk, sig) option *)
Definition parse_witness_extract (w : list nat) : option (list nat * list nat) :=
  parse_witness_concrete w.

(* Check if a witness encoding is canonical.
   For extraction, we always return true since the witness is produced
   by our own serialization function which is canonical by construction. *)
Definition is_canonical_witness_extract (pk : list nat) (sig : list nat) (w : list nat) : bool :=
  true.

(* ================================================================= *)
(* Golden vector generation                                           *)
(* ================================================================= *)

(* Fixed test vectors for reproducible testing *)

(* Test case 1: Small values (single-byte varints) *)
Definition test_pk_small : list nat := [ 0xAB; 0xCD; 0xEF ].
Definition test_sig_small : list nat := [ 0x12; 0x34 ].

(* Test case 2: ML-DSA-44 sized witness *)
(* pk_len = 1312, encoded as 0xFD 0x20 0x05 *)
Definition test_pk_ml_dsa_44 : list nat :=
  repeat 0x42 1312.

(* sig_len = 2420, encoded as 0xFD 0x54 0x09 *)
Definition test_sig_ml_dsa_44 : list nat :=
  repeat 0x99 2420.

(* Test case 3: SLH-DSA-128s sized witness *)
(* pk_len = 32 (single byte) *)
(* sig_len = 7856, encoded as 0xFD 0xB0 0x1E *)
Definition test_pk_slh_dsa : list nat :=
  repeat 0x55 32.

Definition test_sig_slh_dsa : list nat :=
  repeat 0x77 7856.

(* Test case 4: Edge cases *)
Definition test_pk_empty : list nat := [].
Definition test_sig_empty : list nat := [].

(* Test case 5: Large values requiring 0xFE prefix *)
Definition test_pk_large : list nat :=
  repeat 0xAA 70000.  (* Requires 0xFE prefix *)

(* ================================================================= *)
(* Main extraction functions                                          *)
(* ================================================================= *)

(* Generate a golden vector record *)
Record golden_vector : Type := mkGoldenVector {
  gv_name : string;
  gv_pk : list nat;
  gv_sig : list nat;
  gv_witness : list nat;
  gv_is_canonical : bool
}.

(* Convert list of nats to hex string for output *)
Fixpoint nats_to_hex (l : list nat) : string :=
  match l with
  | [] => ""
  | n :: rest =>
      let hex :=
        match n with
        | 0 => "00" | 1 => "01" | 2 => "02" | 3 => "03" | 4 => "04"
        | 5 => "05" | 6 => "06" | 7 => "07" | 8 => "08" | 9 => "09"
        | 10 => "0a" | 11 => "0b" | 12 => "0c" | 13 => "0d" | 14 => "0e" | 15 => "0f"
        | 16 => "10" | 17 => "11" | 18 => "12" | 19 => "13" | 20 => "14"
        | 21 => "15" | 22 => "16" | 23 => "17" | 24 => "18" | 25 => "19"
        | 26 => "1a" | 27 => "1b" | 28 => "1c" | 29 => "1d" | 30 => "1e" | 31 => "1f"
        | _ => "xx"  (* Will be handled by OCaml extraction *)
        end
      in
      append hex (nats_to_hex rest)
  end.

(* Generate all golden vectors *)
Definition generate_golden_vectors : list golden_vector :=
  [
    (* Case 1: Small witness *)
    let w := serialize_witness_extract test_pk_small test_sig_small in
    mkGoldenVector "small" test_pk_small test_sig_small w
      (is_canonical_witness_extract test_pk_small test_sig_small w);

    (* Case 2: ML-DSA-44 sized *)
    let w := serialize_witness_extract test_pk_ml_dsa_44 test_sig_ml_dsa_44 in
    mkGoldenVector "ml_dsa_44" test_pk_ml_dsa_44 test_sig_ml_dsa_44 w
      (is_canonical_witness_extract test_pk_ml_dsa_44 test_sig_ml_dsa_44 w);

    (* Case 3: SLH-DSA-128s sized *)
    let w := serialize_witness_extract test_pk_slh_dsa test_sig_slh_dsa in
    mkGoldenVector "slh_dsa_128s" test_pk_slh_dsa test_sig_slh_dsa w
      (is_canonical_witness_extract test_pk_slh_dsa test_sig_slh_dsa w);

    (* Case 4: Empty (should fail canonical check) *)
    let w := serialize_witness_extract test_pk_empty test_sig_empty in
    mkGoldenVector "empty" test_pk_empty test_sig_empty w
      (is_canonical_witness_extract test_pk_empty test_sig_empty w)
  ].

(* ================================================================= *)
(* OCaml extraction directives                                        *)
(* ================================================================= *)

(* Extract to OCaml with readable names *)
Extraction Language OCaml.

(* Suppress extraction of standard library internals *)
Extract Inductive sumbool => "bool" [ "true" "false" ].
Extract Inductive sumor => "option" [ "Some" "None" ].

(* Module encapsulation for extraction *)
Module WitnessExtraction.

  Definition extract_encode_varint := encode_len_multi.
  Definition extract_decode_varint := decode_len_multi.
  Definition extract_serialize_witness := serialize_witness_concrete.
  Definition extract_parse_witness := parse_witness_concrete.
  Definition extract_generate_vectors := generate_golden_vectors.

End WitnessExtraction.

(* ================================================================= *)
(* Extraction commands (run in Makefile)                             *)
(* ================================================================= *)

(*
 * To extract:
 *   coqc -Q . PQWitness WitnessExtraction.v
 *   coqtop -Q . PQWitness -l WitnessExtraction.v <<EOF
 *     Require Import WitnessExtraction.
 *     Extraction "golden_vectors.ml" WitnessExtraction.
 *   EOF
 *
 * Then compile:
 *   ocamlc -o golden_vectors golden_vectors.ml
 *
 * Run:
 *   ./golden_vectors > coq_vectors.json
 *   cargo test --test po8_golden_vectors  # Compare against Rust
 *)
```


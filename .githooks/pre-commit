#!/bin/bash
# Pre-commit hook: Run all checks before allowing commit
# This ensures GitHub Actions will pass

set -e  # Exit on first error

echo "=========================================="
echo "Running Pre-Commit Checks"
echo "=========================================="

# Check 1: Rust code compiles without errors/warnings
echo ""
echo "[1/5] Checking Rust code..."
cargo check --all-targets --all-features 2>&1 | grep -E "(error|warning:)" || true
cargo clippy --all-targets --all-features -- -D warnings 2>&1 || {
    echo "❌ Rust clippy failed"
    exit 1
}
echo "✓ Rust code OK"

# Check 2: Coq proofs compile
echo ""
echo "[2/5] Checking Coq proofs (this may take 5+ minutes)..."
cd formal/coq
eval $(opam env)
make clean 2>/dev/null || true
make all 2>&1 || {
    echo "❌ Coq proofs failed"
    exit 1
}
cd ../..
echo "✓ Coq proofs OK"

# Check 3: Regenerate and compare PO-4/PO-5/PO-8 extraction artifacts
echo ""
echo "[3/5] Checking PO-4/PO-5/PO-8 extraction artifacts..."
opam exec -- bash ./build_extraction.sh 2>&1 || {
    echo "❌ PO-4/PO-5/PO-8 extraction/vector comparison failed"
    exit 1
}
./verify_compiled_refinement.sh 2>&1 || {
    echo "❌ Compiled PO-8 refinement validation failed"
    exit 1
}
./verify_sighash_refinement.sh 2>&1 || {
    echo "❌ Compiled PO-4 sighash refinement validation failed"
    exit 1
}
./verify_transition_refinement.sh 2>&1 || {
    echo "❌ Compiled PO-5 transition refinement validation failed"
    exit 1
}
if ! git diff --quiet -- formal/coq/extraction/coq_vectors.json rust_vectors.json; then
    echo "❌ Golden vectors changed after regeneration; stage the updated vectors"
    exit 1
fi
echo "✓ PO-4/PO-5/PO-8 extraction artifacts OK"

# Check 4: Rust tests pass
echo ""
echo "[4/5] Running Rust tests..."
cargo test 2>&1 || {
    echo "❌ Rust tests failed"
    exit 1
}
echo "✓ Rust tests OK"

# Check 5: Verify no deprecated actions in workflows
echo ""
echo "[5/5] Checking GitHub Actions workflows..."
if grep -r "coq-community/setup-coq" .github/workflows/ 2>/dev/null; then
    echo "❌ Deprecated setup-coq action found in workflow"
    exit 1
fi
echo "✓ Workflows OK"

echo ""
echo "=========================================="
echo "✅ All pre-commit checks passed!"
echo "=========================================="
echo ""
echo "Summary:"
echo "- Rust code: ✓"
echo "- Coq proofs: ✓"
echo "- PO-4/PO-5/PO-8 extraction artifacts: ✓"
echo "- Rust tests: ✓"
echo "- Workflows: ✓"
echo ""
echo "Ready to commit."
